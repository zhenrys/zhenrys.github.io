  <entry>
    <title>python绘图学习</title>
    <link href="/2024/06/20/python%E5%AD%A6%E4%B9%A0%E7%BB%98%E5%9B%BE/"/>
    <url>/2024/06/20/python%E5%AD%A6%E4%B9%A0%E7%BB%98%E5%9B%BE/</url>
    
    <content type="html"><![CDATA[<h2 id="绘图入门"><a href="#绘图入门" class="headerlink" title="绘图入门"></a>绘图入门</h2><p><em>参考python课件8</em><br>获取数据集请运行</p><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br></pre></td><td class="code"><pre><code class="hljs python"><span class="hljs-keyword">import</span> pandas <span class="hljs-keyword">as</span> pd<br><span class="hljs-keyword">import</span> seaborn <span class="hljs-keyword">as</span> sns<br><span class="hljs-keyword">import</span> matplotlib.pyplot <span class="hljs-keyword">as</span> plt<br>tips = sns.load_dataset(<span class="hljs-string">&quot;tips&quot;</span>)<br></code></pre></td></tr></table></figure><h3 id="matplotlib"><a href="#matplotlib" class="headerlink" title="matplotlib"></a>matplotlib</h3><h4 id="朴素画图"><a href="#朴素画图" class="headerlink" title="朴素画图"></a>朴素画图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br></pre></td><td class="code"><pre><code class="hljs python"><span class="hljs-comment"># 使用matplotlib朴素画图</span><br>plt.plot(ds_1[<span class="hljs-string">&#x27;x&#x27;</span>], ds_1[<span class="hljs-string">&#x27;y&#x27;</span>])<br>plt.plot(ds_1[<span class="hljs-string">&#x27;x&#x27;</span>], ds_1[<span class="hljs-string">&#x27;y&#x27;</span>], <span class="hljs-string">&#x27;o&#x27;</span>)<br><br><span class="hljs-comment"># 大画布上创建子图</span><br>fig = plt.figure()<span class="hljs-comment">#整个画布</span><br>axes1 = fig.add_subplot(<span class="hljs-number">2</span>, <span class="hljs-number">2</span>, <span class="hljs-number">1</span>)<span class="hljs-comment">#第一个子图</span><br>axes1.plot(ds_1[<span class="hljs-string">&#x27;x&#x27;</span>], ds_1[<span class="hljs-string">&#x27;y&#x27;</span>], <span class="hljs-string">&#x27;o&#x27;</span>)<span class="hljs-comment">#画这个子图</span><br></code></pre></td></tr></table></figure><h4 id="直方图"><a href="#直方图" class="headerlink" title="直方图"></a>直方图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br></pre></td><td class="code"><pre><code class="hljs python">fig = plt.figure()<br>axes1 = fig.add_subplot(<span class="hljs-number">1</span>, <span class="hljs-number">1</span>, <span class="hljs-number">1</span>)<br>axes1.hist(tips[<span class="hljs-string">&#x27;total_bill&#x27;</span>], bins=<span class="hljs-number">10</span>)<br>plt.show()<br></code></pre></td></tr></table></figure><h4 id="散点图"><a href="#散点图" class="headerlink" title="散点图"></a>散点图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br></pre></td><td class="code"><pre><code class="hljs python">scatter_plot = plt.figure()<br>axes1 = scatter_plot.add_subplot(<span class="hljs-number">1</span>, <span class="hljs-number">1</span>, <span class="hljs-number">1</span>)<br>axes1.scatter(tips[<span class="hljs-string">&#x27;total_bill&#x27;</span>], tips[<span class="hljs-string">&#x27;tip&#x27;</span>]) <span class="hljs-comment">#scatter plot需要两个变量</span><br></code></pre></td></tr></table></figure><h4 id="箱线图"><a href="#箱线图" class="headerlink" title="箱线图"></a>箱线图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br></pre></td><td class="code"><pre><code class="hljs python">boxplot = plt.figure()<br>axes1 = boxplot.add_subplot(<span class="hljs-number">1</span>, <span class="hljs-number">1</span>, <span class="hljs-number">1</span>)<br>axes1.boxplot(<br>    <span class="hljs-comment"># first argument of boxplot is the data</span><br>    <span class="hljs-comment"># since we are plotting multiple pieces of data</span><br>    <span class="hljs-comment"># we have to put each piece of data into a list</span><br>    [tips[tips[<span class="hljs-string">&#x27;sex&#x27;</span>] == <span class="hljs-string">&#x27;Female&#x27;</span>][<span class="hljs-string">&#x27;tip&#x27;</span>],<br>     tips[tips[<span class="hljs-string">&#x27;sex&#x27;</span>] == <span class="hljs-string">&#x27;Male&#x27;</span>][<span class="hljs-string">&#x27;tip&#x27;</span>]],<br>    <span class="hljs-comment"># we can then pass in an optional labels parameter</span><br>    <span class="hljs-comment"># to label the data we passed</span><br>    labels=[<span class="hljs-string">&#x27;Female&#x27;</span>, <span class="hljs-string">&#x27;Male&#x27;</span>])<br>plt.show()<br></code></pre></td></tr></table></figure><h3 id="seaborn"><a href="#seaborn" class="headerlink" title="seaborn"></a>seaborn</h3><h4 id="直方图，核密度估计"><a href="#直方图，核密度估计" class="headerlink" title="直方图，核密度估计"></a>直方图，核密度估计</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br></pre></td><td class="code"><pre><code class="hljs python">fig, ax = plt.subplots() <span class="hljs-comment">#与plt.figure和add_subplot等价</span><br><br>ax = sns.histplot(tips[<span class="hljs-string">&#x27;total_bill&#x27;</span>])  <span class="hljs-comment">#直方图</span><br><br>ax = sns.displot(tips[<span class="hljs-string">&#x27;total_bill&#x27;</span>])  <span class="hljs-comment">#核密度估计</span><br></code></pre></td></tr></table></figure><h4 id="频数图"><a href="#频数图" class="headerlink" title="频数图"></a>频数图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br></pre></td><td class="code"><pre><code class="hljs python">fig, ax = plt.subplots()<br><br>ax = sns.distplot(tips[<span class="hljs-string">&#x27;total_bill&#x27;</span>], rug=<span class="hljs-literal">True</span>)<br></code></pre></td></tr></table></figure><h4 id="计数图"><a href="#计数图" class="headerlink" title="计数图"></a>计数图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br></pre></td><td class="code"><pre><code class="hljs python">fig, ax = plt.subplots()<br><br>ax = sns.countplot(y=<span class="hljs-string">&#x27;day&#x27;</span>, data=tips)<br></code></pre></td></tr></table></figure><h4 id="散点图-1"><a href="#散点图-1" class="headerlink" title="散点图"></a>散点图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br></pre></td><td class="code"><pre><code class="hljs python">fig, ax = plt.subplots()<br><br>ax = sns.regplot(x=<span class="hljs-string">&#x27;total_bill&#x27;</span>, y=<span class="hljs-string">&#x27;tip&#x27;</span>, data=tips) <span class="hljs-comment"># 返回一个子图</span><br><br>fig = sns.lmplot(x=<span class="hljs-string">&#x27;total_bill&#x27;</span>, y=<span class="hljs-string">&#x27;tip&#x27;</span>, data=tips) <span class="hljs-comment"># 返回整个图片</span><br><br><span class="hljs-comment">#lmplot创建figure，而regplot创建一个axes</span><br><br><span class="hljs-comment">#联合图</span><br>joint = sns.jointplot(x=<span class="hljs-string">&#x27;total_bill&#x27;</span>, y=<span class="hljs-string">&#x27;tip&#x27;</span>, data=tips)  <span class="hljs-comment">#jointplot同样创建一个figure</span><br><br><span class="hljs-comment">#联合图-蜂巢风格</span><br>hexbin = sns.jointplot(x=<span class="hljs-string">&quot;total_bill&quot;</span>, y=<span class="hljs-string">&quot;tip&quot;</span>, data=tips, kind=<span class="hljs-string">&quot;hex&quot;</span>)<br><br></code></pre></td></tr></table></figure><h4 id="条形图"><a href="#条形图" class="headerlink" title="条形图"></a>条形图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br></pre></td><td class="code"><pre><code class="hljs python">fig, ax = plt.subplots()<br><br>ax = sns.barplot(x=<span class="hljs-string">&#x27;time&#x27;</span>, y=<span class="hljs-string">&#x27;total_bill&#x27;</span>, data=tips)  <span class="hljs-comment">#默认计算total_bill的均值</span><br><br>plt.show()<br></code></pre></td></tr></table></figure><h4 id="箱线图-1"><a href="#箱线图-1" class="headerlink" title="箱线图"></a>箱线图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br></pre></td><td class="code"><pre><code class="hljs python">fig, ax = plt.subplots()<br><br>ax = sns.boxplot(x=<span class="hljs-string">&#x27;time&#x27;</span>, y=<span class="hljs-string">&#x27;total_bill&#x27;</span>, data=tips)<br><br>plt.show()<br></code></pre></td></tr></table></figure><p>hue参数</p><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br></pre></td><td class="code"><pre><code class="hljs python">box, ax = plt.subplots()<br><br>ax = sns.boxplot(x=<span class="hljs-string">&#x27;day&#x27;</span>, y=<span class="hljs-string">&#x27;total_bill&#x27;</span>, hue=<span class="hljs-string">&#x27;smoker&#x27;</span>, data=tips)<br><br>plt.show()<br></code></pre></td></tr></table></figure><h4 id="小提琴图"><a href="#小提琴图" class="headerlink" title="小提琴图"></a>小提琴图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br></pre></td><td class="code"><pre><code class="hljs python">violin, ax = plt.subplots()<br><br>ax = sns.violinplot(x=<span class="hljs-string">&#x27;time&#x27;</span>, y=<span class="hljs-string">&#x27;total_bill&#x27;</span>, data=tips)<br><br>plt.show()<br></code></pre></td></tr></table></figure><p>hue参数<br>split参数（歪葫芦）</p><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br></pre></td><td class="code"><pre><code class="hljs python">box, ax = plt.subplots()<br><br>ax = sns.violinplot(x=<span class="hljs-string">&#x27;day&#x27;</span>, y=<span class="hljs-string">&#x27;total_bill&#x27;</span>, hue=<span class="hljs-string">&#x27;smoker&#x27;</span>, data=tips, split=<span class="hljs-literal">True</span>) <br><br>plt.show()<br></code></pre></td></tr></table></figure><h4 id="成对关系图"><a href="#成对关系图" class="headerlink" title="成对关系图"></a>成对关系图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br><span class="line">10</span><br><span class="line">11</span><br><span class="line">12</span><br><span class="line">13</span><br><span class="line">14</span><br><span class="line">15</span><br><span class="line">16</span><br><span class="line">17</span><br><span class="line">18</span><br><span class="line">19</span><br></pre></td><td class="code"><pre><code class="hljs python"><span class="hljs-comment">#预处理</span><br>tips_numeric = tips.iloc[:,<span class="hljs-number">0</span>:-<span class="hljs-number">1</span>] <span class="hljs-comment">#去掉最后一列</span><br>---<br>sns.pairplot(tips_numeric)    <span class="hljs-comment">#total_bill,tip,size之间的关系</span><br>---<br>sns.PairGrid(tips_numeric)<br><br>pair_grid = pair_grid.map_upper(sns.regplot)<br>pair_grid = pair_grid.map_lower(sns.kdeplot)<br>pair_grid = pair_grid.map_diag(sns.distplot, rug=<span class="hljs-literal">True</span>)<br>---<br>sns.lmplot(x=<span class="hljs-string">&#x27;total_bill&#x27;</span>, y=<span class="hljs-string">&#x27;tip&#x27;</span>, data=tips,fit_reg=<span class="hljs-literal">False</span>,hue=<span class="hljs-string">&#x27;sex&#x27;</span>, markers=[<span class="hljs-string">&#x27;o&#x27;</span>, <span class="hljs-string">&#x27;x&#x27;</span>],)<br>---<br><span class="hljs-comment">#分面操作</span><br>sns.FacetGrid(tips, col=<span class="hljs-string">&#x27;time&#x27;</span>, row=<span class="hljs-string">&#x27;smoker&#x27;</span>, hue=<span class="hljs-string">&#x27;sex&#x27;</span>) <span class="hljs-comment">#行和列表示不同的变量</span><br><br>facet.<span class="hljs-built_in">map</span>(plt.scatter, <span class="hljs-string">&#x27;total_bill&#x27;</span>, <span class="hljs-string">&#x27;tip&#x27;</span>)<br>---<br>sns.catplot(x=<span class="hljs-string">&#x27;day&#x27;</span>, y=<span class="hljs-string">&#x27;total_bill&#x27;</span>, hue=<span class="hljs-string">&#x27;sex&#x27;</span>, data=tips, row=<span class="hljs-string">&#x27;smoker&#x27;</span>, col=<span class="hljs-string">&#x27;time&#x27;</span>, kind=<span class="hljs-string">&#x27;violin&#x27;</span>, split=<span class="hljs-literal">True</span>)<br></code></pre></td></tr></table></figure><h3 id="Pandas绘图"><a href="#Pandas绘图" class="headerlink" title="Pandas绘图"></a>Pandas绘图</h3><h4 id="条形图-1"><a href="#条形图-1" class="headerlink" title="条形图"></a>条形图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br></pre></td><td class="code"><pre><code class="hljs python"><span class="hljs-comment"># on a series</span><br>fig, ax = plt.subplots()<br>ax = tips[<span class="hljs-string">&#x27;total_bill&#x27;</span>].plot.hist()<br><br><span class="hljs-comment"># on a dataframe</span><br>fig, ax = plt.subplots()<br>ax = tips[[<span class="hljs-string">&#x27;total_bill&#x27;</span>, <span class="hljs-string">&#x27;tip&#x27;</span>]].plot.hist(alpha=<span class="hljs-number">0.5</span>, bins=<span class="hljs-number">20</span>, ax=ax)<br></code></pre></td></tr></table></figure><h4 id="核密度估计"><a href="#核密度估计" class="headerlink" title="核密度估计"></a>核密度估计</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br><span class="line">9</span><br></pre></td><td class="code"><pre><code class="hljs python"><span class="hljs-comment"># on a series</span><br>fig, ax = plt.subplots()<br>ax = tips[<span class="hljs-string">&#x27;total_bill&#x27;</span>].plot.kde()<br>plt.show()<br><br><span class="hljs-comment"># on a dataframe</span><br>fig, ax = plt.subplots()<br>ax = tips[[<span class="hljs-string">&#x27;total_bill&#x27;</span>, <span class="hljs-string">&#x27;tip&#x27;</span>]].plot.kde(ax=ax)<br>plt.show()<br></code></pre></td></tr></table></figure><h4 id="散点图-2"><a href="#散点图-2" class="headerlink" title="散点图"></a>散点图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><span class="line">5</span><br><span class="line">6</span><br><span class="line">7</span><br><span class="line">8</span><br></pre></td><td class="code"><pre><code class="hljs python">fig, ax = plt.subplots()<br>ax = tips.plot.scatter(x=<span class="hljs-string">&#x27;total_bill&#x27;</span>, y=<span class="hljs-string">&#x27;tip&#x27;</span>, ax=ax)<br>plt.show()<br><br><span class="hljs-comment">#蜂巢形式</span><br>fig, ax = plt.subplots()<br>ax = tips.plot.hexbin(x=<span class="hljs-string">&#x27;total_bill&#x27;</span>, y=<span class="hljs-string">&#x27;tip&#x27;</span>, gridsize=<span class="hljs-number">10</span>, ax=ax)<br>plt.show()<br></code></pre></td></tr></table></figure><h4 id="箱线图-2"><a href="#箱线图-2" class="headerlink" title="箱线图"></a>箱线图</h4><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br></pre></td><td class="code"><pre><code class="hljs python">fig, ax = plt.subplots()<br>ax = tips.plot.box(ax=ax)<br>plt.show()<br></code></pre></td></tr></table></figure><h3 id="关于绘图区域的文字设置"><a href="#关于绘图区域的文字设置" class="headerlink" title="关于绘图区域的文字设置"></a>关于绘图区域的文字设置</h3><figure class="highlight python"><table><tr><td class="gutter"><pre><span class="line">1</span><br><span class="line">2</span><br><span class="line">3</span><br><span class="line">4</span><br><sp